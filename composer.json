{
    "name": "toanchet/toanchetpay-sdk",
    "description": "ToanchetPay Payment Gateway SDK for PHP — supports all payment types: standard, MPGS, KHQR, POS, mobile deeplink.",
    "type": "library",
    "keywords": ["toanchet", "toanchetpay", "payment", "gateway", "khqr", "mpgs", "cambodia"],
    "homepage": "https://github.com/acleda/toanchetpay-php-sdk",
    "license": "MIT",
    "require": {
        "php": ">=7.4",
        "ext-curl": "*",
        "ext-hash": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0|^10.0",
        "guzzlehttp/guzzle": "^7.0",
        "endroid/qr-code": "^4.0|^5.0"
    },
    "suggest": {
        "guzzlehttp/guzzle": "Provides a Guzzle HTTP adapter instead of cURL.",
        "endroid/qr-code": "Enables QR code image generation from qrValue."
    },
    "autoload": {
        "psr-4": {
            "ToanchetPay\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ToanchetPay\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
